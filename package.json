{
  "name": "patient-biomarkers",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w packages/server run dev",
    "dev:client": "npm -w packages/client run dev",
    "build": "npm -w packages/client run build",
    "start": "npm -w packages/server run db:deploy && npm -w packages/server run start",
    "test": "npm run test --workspaces",
    "db:generate": "npm -w packages/server run db:generate",
    "db:migrate": "npm -w packages/server run db:migrate",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
